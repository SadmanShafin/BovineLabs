@startuml DaggerfallCombatSm

/'! $CONFIG : toml
SmRunnerSettings.transpilerId = "CSharp"

RenderConfig.CSharp.Usings = """
using System;
using Unity.Entities;
using Unity.Mathematics;
using BovineLabs.Core;
using BovineLabs.Essence;
using BovineLabs.Essence.Data;
using BovineLabs.Core.Utility; // For GlobalRandom if needed, or we use Unity.Mathematics.Random
"""

RenderConfig.CSharp.ClassCode = """
    // 1. --- BOVINELABS ESSENCE FACET ---
    // Represents the Defender's ECS Components
    public partial struct DefenderFacet : IFacet
    {
        public DynamicBuffer<Stat> Stats;
        public IntrinsicWriter Intrinsics;
    }

    // 2. --- ESSENCE KEYS ---
    public static class StatKeys 
    {
        public const ushort ArmorClass = 1; // Lower is better in Daggerfall, but we'll adapt it
        public const ushort Agility = 2;
        public const ushort Luck = 3;
        public const ushort Dodging = 4;
        
        public const ushort MinMaterialToHit = 10; // e.g., 2 = Silver, 5 = Mithril
        
        public const ushort ResistFire = 20;
        public const ushort ResistFrost = 21;
        public const ushort ResistPoison = 22;
        public const ushort ResistShock = 23;
        public const ushort ResistMagic = 24;
    }

    public static class IntrinsicKeys 
    {
        public const ushort Health = 1;
        public const ushort Fatigue = 2;
    }

    public enum DamageElement : byte
    {
        Physical = 0,
        Fire = 1,
        Frost = 2,
        Poison = 3,
        Shock = 4,
        Magic = 5
    }

    // 3. --- STATE MACHINE FIELDS ---
    
    // Attacker Inputs (passed in before DispatchEvent)
    public int AttackerWeaponSkill;
    public int AttackerAgility;
    public int AttackerLuck;
    public int AttackerMaterialLevel; // 0=Iron, 1=Steel, 2=Silver, ... 9=Daedric
    public int AttackerMinDamage;
    public int AttackerMaxDamage;
    public DamageElement AttackElement;
    public uint RandomSeed;

    // Flow State (calculated during the graph execution)
    public bool IsHit;
    public bool IsMaterialEffective;
    public bool IsResisted;
    public int FinalDamage;

    // ECS Context
    public DefenderFacet Defender;

    // Internal Random state
    private Unity.Mathematics.Random _rng;

    // 4. --- CALCULATION STEP METHODS ---
    
    private void InitCombat()
    {
        _rng = new Unity.Mathematics.Random(RandomSeed == 0 ? 1 : RandomSeed);
        IsHit = false;
        IsMaterialEffective = false;
        IsResisted = false;
        FinalDamage = 0;
        Console.WriteLine("--- Daggerfall Combat Sequence Started ---");
    }

    private void DoRollToHit()
    {
        // Attacker Hit Chance
        int hitChance = AttackerWeaponSkill + (AttackerAgility / 10) + (AttackerLuck / 10);
        
        // Defender Evasion
        int defArmorClass = Defender.Stats.GetValueFloor(StatKeys.ArmorClass, 0); 
        int defAgility = Defender.Stats.GetValueFloor(StatKeys.Agility, 50);
        int defLuck = Defender.Stats.GetValueFloor(StatKeys.Luck, 50);
        int defDodging = Defender.Stats.GetValueFloor(StatKeys.Dodging, 0);

        int evasion = defArmorClass + (defAgility / 10) + (defLuck / 10) + (defDodging / 4);
        
        // Daggerfall hit formula approximation
        int targetRoll = hitChance - evasion;
        targetRoll = math.clamp(targetRoll, 3, 97); // 3% min chance, 97% max chance

        int roll = _rng.NextInt(1, 101);
        IsHit = roll <= targetRoll;

        Console.WriteLine($"[To-Hit] Roll: {roll} vs Target: {targetRoll}. Hit? {IsHit}");
    }

    private void DoCheckMaterial()
    {
        int requiredMaterial = Defender.Stats.GetValueFloor(StatKeys.MinMaterialToHit, 0);
        IsMaterialEffective = AttackerMaterialLevel >= requiredMaterial;
        
        Console.WriteLine($"[Material] Weapon Material: {AttackerMaterialLevel}, Required: {requiredMaterial}. Effective? {IsMaterialEffective}");
    }

    private void DoCheckResistance()
    {
        if (AttackElement == DamageElement.Physical)
        {
            IsResisted = false;
            return;
        }

        // Map element to stat key
        ushort statKey = AttackElement switch
        {
            DamageElement.Fire => StatKeys.ResistFire,
            DamageElement.Frost => StatKeys.ResistFrost,
            DamageElement.Poison => StatKeys.ResistPoison,
            DamageElement.Shock => StatKeys.ResistShock,
            DamageElement.Magic => StatKeys.ResistMagic,
            _ => 0
        };

        int resistance = Defender.Stats.GetValueFloor(statKey, 0); // 0-100%
        int roll = _rng.NextInt(1, 101);
        IsResisted = roll <= resistance;

        Console.WriteLine($"[Resistance] Element: {AttackElement}, Resist Chance: {resistance}%, Roll: {roll}. Resisted? {IsResisted}");
    }

    private void DoCalcDamage()
    {
        // Weapon Damage Roll
        FinalDamage = _rng.NextInt(AttackerMinDamage, AttackerMaxDamage + 1);
        
        // Add Material Modifier (+1 damage per material level above steel generally, simplified here)
        FinalDamage += math.max(0, AttackerMaterialLevel - 1);
        
        Console.WriteLine($"[Damage] Calculated Damage: {FinalDamage}");
    }

    private void DoApplyDamage()
    {
        // BovineLabs Essence IntrinsicWriter automatically handles limits, death events, etc.
        Defender.Intrinsics.Subtract(IntrinsicKeys.Health, FinalDamage);
        Console.WriteLine($"[Apply] Deducted {FinalDamage} Health from Defender.");
    }

    private void LogMiss() => Console.WriteLine("[Result] Attack Missed.");
    private void LogImmune() => Console.WriteLine("[Result] Defender is Immune to this material.");
    private void LogResisted() => Console.WriteLine("[Result] Defender Resisted the attack.");
"""
'/

state IDLE {
}

state COMBAT_SEQUENCE {
    
    ' Entry point into the flow
    COMBAT_SEQUENCE : enter / InitCombat();

    [*] -> CHECK_HIT
    
    state CHECK_HIT {
        CHECK_HIT : enter / DoRollToHit();
    }
    
    state CHECK_MATERIAL {
        CHECK_MATERIAL : enter / DoCheckMaterial();
    }
    
    state CHECK_RESISTANCE {
        CHECK_RESISTANCE : enter / DoCheckResistance();
    }
    
    state CALCULATE_DAMAGE {
        CALCULATE_DAMAGE : enter / DoCalcDamage();
    }
    
    state APPLY_DAMAGE {
        APPLY_DAMAGE : enter / DoApplyDamage();
    }

    ' Outcome States (Leaves of the logic tree)
    state END_MISS {
        END_MISS : enter / LogMiss();
    }
    state END_IMMUNE {
        END_IMMUNE : enter / LogImmune();
    }
    state END_RESISTED {
        END_RESISTED : enter / LogResisted();
    }

    ' --- LOGIC BRANCHING ---
    ' StateSmith evaluates these transitions immediately because they lack an Event trigger.
    
    ' 1. Did we hit?
    CHECK_HIT --> CHECK_MATERIAL : [IsHit]
    CHECK_HIT --> END_MISS : else

    ' 2. Is the weapon material strong enough to pierce immunity (e.g. Silver vs Werewolf)?
    CHECK_MATERIAL --> CHECK_RESISTANCE : [IsMaterialEffective]
    CHECK_MATERIAL --> END_IMMUNE : else

    ' 3. Did the defender make their saving throw / resistance check?
    CHECK_RESISTANCE --> CALCULATE_DAMAGE : [!IsResisted]
    CHECK_RESISTANCE --> END_RESISTED : else

    ' 4. Finalize
    CALCULATE_DAMAGE --> APPLY_DAMAGE
}

[*] -> IDLE

' The event that starts the entire DAG
IDLE --> COMBAT_SEQUENCE : PROCESS_ATTACK

' All outcomes return the state machine to IDLE, waiting for the next attack
END_MISS --> IDLE
END_IMMUNE --> IDLE
END_RESISTED --> IDLE
APPLY_DAMAGE --> IDLE

@enduml